<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission"
        xmlns:tools="http://schemas.android.com/tools" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!-- Для self-update: запускаем installer через ACTION_VIEW на content:// URI FileProvider'а. -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <application
        android:name=".AnubisApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Anubis">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Anubis">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".service.ShortcutActivity"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:exported="false"
            android:excludeFromRecents="true"
            android:taskAffinity="" />

        <service
            android:name=".service.VpnMonitorService"
            android:foregroundServiceType="specialUse"
            android:exported="false" />

        <service
            android:name=".service.StealthVpnService"
            android:permission="android.permission.BIND_VPN_SERVICE"
            android:foregroundServiceType="specialUse"
            android:exported="false">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
        </service>

        <service
            android:name=".service.StealthTileService"
            android:icon="@drawable/ic_shield"
            android:label="@string/tile_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <receiver
            android:name=".service.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Обрабатывает Freeze/Unfreeze/Dismiss actions из hit-нотификаций. -->
        <receiver
            android:name=".service.FreezeActionReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="sgnv.anubis.app.FREEZE_HIT" />
                <action android:name="sgnv.anubis.app.UNFREEZE_HIT" />
                <action android:name="sgnv.anubis.app.DISMISS_HIT" />
            </intent-filter>
        </receiver>

        <!--
          ADB-управление аудит-режимом: permission DUMP держит только shell,
          чужие приложения без root этот broadcast послать не могут.
          Использование:
            adb shell am broadcast -a sgnv.anubis.app.ADB_ENABLE_AUDIT
            adb shell am broadcast -a sgnv.anubis.app.ADB_DISABLE_AUDIT
        -->
        <receiver
            android:name=".service.AdbAuditReceiver"
            android:exported="true"
            android:permission="android.permission.DUMP">
            <intent-filter>
                <action android:name="sgnv.anubis.app.ADB_ENABLE_AUDIT" />
                <action android:name="sgnv.anubis.app.ADB_DISABLE_AUDIT" />
            </intent-filter>
        </receiver>

        <!-- Shizuku provider -->
        <provider
            android:name="rikka.shizuku.ShizukuProvider"
            android:authorities="${applicationId}.shizuku"
            android:multiprocess="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.INTERACT_ACROSS_USERS_FULL" />

        <!--
          FileProvider для self-update APK. Authorities зависят от applicationId,
          поэтому debug-сборка (".debug") получает отдельный authority и не
          конфликтует с релизом автора, если оба установлены рядом.
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
